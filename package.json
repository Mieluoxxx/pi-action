{
  "name": "pi-action",
  "version": "0.1.0",
  "description": "Run the Pi coding agent on GitHub issues and pull requests.",
  "license": "MIT",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx test/*.test.ts",
    "test:coverage": "node --test --experimental-test-coverage \"--test-coverage-include=src/**/*.ts\" --test-coverage-exclude=src/index.ts --test-coverage-lines=95 --test-coverage-branches=80 --test-coverage-functions=90 --import tsx test/*.test.ts",
    "check": "biome check src test",
    "format": "biome format --write src test",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "@actions/io": "^1.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.14.0",
    "@vercel/ncc": "^0.38.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
